# Nizhal ML Backend Configuration

# Google Safe Browsing API Key (optional, but recommended for maximum protection)
# Get your key at: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=

# Allowed CORS origins (comma-separated). Set to your Chrome extension ID for production.
# Example: chrome-extension://abcdefghijklmnopqrstuvwxyz
ALLOWED_ORIGINS=*

# Rate limit for the /predict endpoint (requests per time window per IP)
RATE_LIMIT=30/minute

# SSL certificate paths (defaults work with the auto-generated self-signed cert)
SSL_KEYFILE=/app/certs/key.pem
SSL_CERTFILE=/app/certs/cert.pem
